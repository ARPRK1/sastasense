# Copy this file to ".env" and edit as needed. All values are optional.

# Try real live scraping of India retail sites. If blocked, demo data is used.
LIVE_SCRAPING=true
# Keep demo results as a safety net so the app is never empty.
DEMO_FALLBACK=true

# How often (minutes) tracked prices refresh in the background (drives alerts).
REFRESH_INTERVAL_MIN=60

# --- Optional e-mail alerts. Leave blank to use in-app alerts only. ---
# For Gmail, use an App Password (not your normal password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM=
